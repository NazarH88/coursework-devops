pipeline {

    agent any

    environment {
        IMAGE_NAME     = "coursework-flask-app"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        COMPOSE_FILE   = "docker-compose.yml"
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    stages {

        stage('Checkout') {
            steps {
                echo "==> Клонування репозиторію..."
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "==> Збірка Docker-образу..."
                sh '''
                    docker build \
                      -f docker/Dockerfile \
                      -t ${IMAGE_NAME}:${IMAGE_TAG} \
                      -t ${IMAGE_NAME}:latest \
                      .
                '''
            }
        }

        stage('Test') {
            steps {
                echo "==> Перевірка health endpoint..."

                sh '''
                    docker rm -f test_flask 2>/dev/null || true

                    docker run -d \
                      --name test_flask \
                      -p 5001:5000 \
                      -e APP_ENV=testing \
                      ${IMAGE_NAME}:${IMAGE_TAG}

                    sleep 10

                    curl http://localhost:5001/api/health

                    docker rm -f test_flask
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo "==> Docker Compose deploy..."

                sh '''
                    docker compose down || true
                    docker compose up -d --build
                '''
            }
        }

        stage('Verify') {
            steps {
                echo "==> Перевірка nginx..."

                sh '''
                    sleep 10
                    curl http://localhost/api/health
                    docker compose ps
                '''
            }
        }
    }

    post {

        success {
            echo 'Pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed!'
        }

        always {
            sh 'docker image prune -f || true'
        }
    }
}
